{
  "rate_limits": {
    "version": "1.00",
    "services": {
      "default": {
        "requests_per_minute": 30,
        "requests_per_hour": 500,
        "concurrent_max": 5,
        "retry_after_seconds": 30,
        "max_retries": 3
      },
      "huggingface": {
        "requests_per_minute": 10,
        "requests_per_hour": 100,
        "concurrent_max": 2,
        "retry_after_seconds": 30,
        "max_retries": 3
      },
      "ollama": {
        "requests_per_minute": 20,
        "requests_per_hour": 300,
        "concurrent_max": 3,
        "retry_after_seconds": 15,
        "max_retries": 3
      }
    }
  }
}
